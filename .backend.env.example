# ─────────────────────────────────────────────────────────────
# バックエンド切り替え設定
# このファイルをコピーして .backend.env を作成してください:
#   cp .backend.env.example .backend.env
#
# 切り替えには make switch-rails / make switch-go も使えます
# ─────────────────────────────────────────────────────────────

# Rails に向ける場合（Docker 内サービス名で指定）
BACKEND_URL=http://backend_rails:7777

# Go に向ける場合（ホストで go run しているため host.docker.internal を使用）
# BACKEND_URL=http://host.docker.internal:1099
